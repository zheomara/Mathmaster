# Client-side (Vite) config
# This MUST be an absolute URL for Capacitor/native builds (relative URLs won't work from `capacitor://localhost`).
VITE_SOLVER_API_BASE="https://your-vercel-app.vercel.app"

# Server-side (Vercel Function) keys
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional server-side fallback provider (Puter)
# Use a dedicated token/account for server-side usage.
PUTER_AUTH_TOKEN="YOUR_PUTER_AUTH_TOKEN"
